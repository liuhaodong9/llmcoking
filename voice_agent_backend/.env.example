# ----------------------------
# DeepSeek (OpenAI-compatible)
# ----------------------------
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ----------------------------
# ASR provider
# ----------------------------
ASR_PROVIDER=whisper          # whisper|xfyun_rtasr|doubao_asr|doubao_rtasr
ASR_FALLBACK_WHISPER=true     # fallback to local whisper when remote provider fails/unavailable
ASR_CONTEXT_WINDOW_TURNS=6    # turns kept for ASR confusion reranking
ASR_PARTIAL_ENABLED=true
ASR_PARTIAL_INTERVAL_MS=700
ASR_PARTIAL_MIN_AUDIO_MS=640
ASR_PARTIAL_WINDOW_SEC=10
ASR_PARTIAL_ALLOW_REMOTE_PROVIDER=false

# ----------------------------
# ASR (faster-whisper)
# ----------------------------
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto      # auto|cpu|cuda
WHISPER_COMPUTE_TYPE=auto # auto|int8|float16
WHISPER_LANGUAGE=zh       # zh|en|ja|... ; set auto/empty for auto-detect
ASR_SCRIPT_TARGET=simplified # simplified|traditional|raw

# ----------------------------
# ASR (iFlytek Real-Time ASR / RTASR)
# Doc: https://www.xfyun.cn/doc/asr/rtasr/API.html
# ----------------------------
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_RTASR_URL=wss://rtasr.xfyun.cn/v1/ws
XFYUN_RTASR_LANG=cn          # cn|en
XFYUN_RTASR_CHUNK_MS=40      # send audio frame interval
XFYUN_RTASR_RECV_TIMEOUT_SEC=5

# ----------------------------
# ASR (Doubao / Volcengine OpenSpeech flash recognize)
# Doc: https://www.volcengine.com/docs/6561/1354869
# ----------------------------
DOUBAO_API_APP_KEY=
DOUBAO_API_ACCESS_KEY=
DOUBAO_API_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
DOUBAO_ASR_MODEL_NAME=bigmodel
DOUBAO_ASR_UID=voice-agent
DOUBAO_ASR_TIMEOUT_SEC=30
DOUBAO_ASR_ENABLE_PUNC=true
DOUBAO_ASR_ENABLE_ITN=true

# ----------------------------
# ASR (Doubao Realtime WebSocket, recommended for incremental revision)
# Doc: https://www.volcengine.com/docs/6561/1631584
# ----------------------------
DOUBAO_RTASR_URL=wss://ai-gateway.vei.volces.com/v1/realtime
DOUBAO_RTASR_API_KEY=
DOUBAO_RTASR_MODEL=bigmodel
DOUBAO_RTASR_RESOURCE_ID=volc.bigasr.sauc.duration
DOUBAO_RTASR_UID=voice-agent
DOUBAO_RTASR_OPEN_TIMEOUT_SEC=10
DOUBAO_RTASR_COMMIT_TIMEOUT_SEC=10
DOUBAO_RTASR_RECV_TIMEOUT_SEC=8
DOUBAO_RTASR_ENABLE_PUNC=true
DOUBAO_RTASR_ENABLE_ITN=true

# ----------------------------
# Silero VAD
# ----------------------------
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250
VAD_MIN_SILENCE_MS=500

# ----------------------------
# TTS provider
# ----------------------------
# doubao_tts: Doubao emotional TTS via API
# spark_tts: local Spark-TTS CLI
TTS_PROVIDER=doubao_tts

# ----------------------------
# Doubao TTS (OpenSpeech HTTP)
# Doc: https://www.volcengine.com/docs/6561/1598757
# ----------------------------
DOUBAO_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_KEY=
DOUBAO_TTS_RESOURCE_ID=volc.service_type.10029
DOUBAO_TTS_UID=voice-agent
DOUBAO_TTS_VOICE_TYPE=BV001_streaming
DOUBAO_TTS_ENCODING=mp3
DOUBAO_TTS_SPEED_RATIO=1.0
DOUBAO_TTS_VOLUME_RATIO=1.0
DOUBAO_TTS_PITCH_RATIO=1.0
DOUBAO_TTS_EMOTION=neutral
DOUBAO_TTS_EMOTION_SCALE=1.0
DOUBAO_TTS_SILENCE_DURATION_MS=125
DOUBAO_TTS_WITH_FRONTEND=true
DOUBAO_TTS_FRONTEND_TYPE=unitTson
DOUBAO_TTS_TIMEOUT_SEC=20

# ----------------------------
# Spark-TTS (CLI mode, local)
# ----------------------------
# Point to the python executable inside your Spark-TTS conda env
SPARKTTS_PYTHON=
# Spark-TTS repo working directory (where `cli` module exists)
SPARKTTS_WORKDIR=
# Model dir, e.g. pretrained_models/Spark-TTS-0.5B
SPARKTTS_MODEL_DIR=
# Device index or "cpu", e.g. 0
SPARKTTS_DEVICE=0
# Optional cloning prompt
SPARKTTS_PROMPT_TEXT=
SPARKTTS_PROMPT_SPEECH_PATH=

# Enable/disable server TTS (if false, frontend will fallback to browser TTS)
ENABLE_SERVER_TTS=false

# Beginner tip: keep ENABLE_SERVER_TTS=false for the first run.
